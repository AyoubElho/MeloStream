@startuml
!pragma layout smetana
left to right direction
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ArrowColor #6B7280
skinparam ActorBorderColor #2563EB
skinparam ActorBackgroundColor #EFF6FF
skinparam UsecaseBorderColor #0F766E
skinparam UsecaseBackgroundColor #ECFDF5
skinparam RectangleBorderColor #D1D5DB
skinparam RectangleBackgroundColor #F8FAFC

title MeloStream - Cas du visiteur

actor "Visiteur" as Visitor

usecase "S'inscrire" as UCRegister
usecase "Se connecter" as UCLogin

Visitor --> UCRegister
Visitor --> UCLogin
@enduml
