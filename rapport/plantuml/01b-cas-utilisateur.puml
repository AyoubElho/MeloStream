@startuml
!pragma layout smetana
left to right direction
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ArrowColor #6B7280
skinparam ActorBorderColor #2563EB
skinparam ActorBackgroundColor #EFF6FF
skinparam UsecaseBorderColor #0F766E
skinparam UsecaseBackgroundColor #ECFDF5
skinparam RectangleBorderColor #D1D5DB
skinparam RectangleBackgroundColor #F8FAFC

title MeloStream - Cas de l'utilisateur

actor "Utilisateur" as User

usecase "Consulter et modifier\nle profil" as UCProfile
usecase "Rechercher un titre" as UCSearch
usecase "Écouter un titre" as UCListen
usecase "Gérer les favoris" as UCFavorites
usecase "Gérer les playlists" as UCPlaylists
usecase "Partager un titre" as UCShare
usecase "Charger un lien\nde partage" as UCSharedSong

User --> UCProfile
User --> UCSearch
User --> UCListen
User --> UCFavorites
User --> UCPlaylists
User --> UCShare
User --> UCSharedSong
@enduml
